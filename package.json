{
  "name": "@stellar-split/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the StellarSplit on-chain invoice splitting dApp",
  "license": "MIT",
  "author": "StellarSplit Contributors",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ledgerhq/hw-app-str": "^6.29.0",
    "@ledgerhq/hw-transport-webhid": "^6.29.0",
    "@stellar/freighter-api": "^3.0.0",
    "@stellar/stellar-sdk": "^13.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
